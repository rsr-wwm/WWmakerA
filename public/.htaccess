# Apache configuration for React HashRouter SPA
# This helps with 403 Forbidden errors and basic optimization

# Ensure index.html is the directory index
DirectoryIndex index.html

# Disable directory browsing
Options -Indexes

# Handle basic CORS if needed
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
</IfModule>

# Basic caching for assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# If they ever switch to BrowserRouter, they would need these rules:
# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteBase /
#   RewriteRule ^index\.html$ - [L]
#   RewriteCond %{REQUEST_FILENAME} !-f
#   RewriteCond %{REQUEST_FILENAME} !-d
#   RewriteCond %{REQUEST_FILENAME} !-l
#   RewriteRule . /index.html [L]
# </IfModule>
